# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:pass@host:5432/dbname
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/?appName=Cluster0

# ─── Auth ────────────────────────────────────────────────────────────────────
NEXTAUTH_SECRET=generate-a-long-random-string
NEXTAUTH_URL=https://adaptable-success-production.up.railway.app

# ─── AWS Core ────────────────────────────────────────────────────────────────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key

# ─── SQS Queue URLs ──────────────────────────────────────────────────────────
SQS_REVIEW_INGESTION_URL=https://sqs.us-east-1.amazonaws.com/123456789/review-ingestion-queue
SQS_NLP_TAGGING_URL=https://sqs.us-east-1.amazonaws.com/123456789/nlp-tagging-queue
SQS_AI_DRAFT_URL=https://sqs.us-east-1.amazonaws.com/123456789/ai-draft-queue

# ─── S3 ──────────────────────────────────────────────────────────────────────
S3_BUCKET_NAME=reviewpulse-payloads

# ─── SES ─────────────────────────────────────────────────────────────────────
SES_FROM_EMAIL=noreply@yourdomain.io
SES_REPLY_TO=support@yourdomain.io

# ─── AI Providers ────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your-anthropic-api-key
OPENAI_API_KEY=your-openai-api-key

# ─── OAuth Providers ─────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
FACEBOOK_CLIENT_ID=your-facebook-app-id
FACEBOOK_CLIENT_SECRET=your-facebook-app-secret
YELP_CLIENT_ID=your-yelp-client-id
YELP_CLIENT_SECRET=your-yelp-client-secret

# ─── App ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://adaptable-success-production.up.railway.app
NEXT_PUBLIC_APP_NAME=ReviewPulse
